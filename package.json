{
  "name": "digikladde-workspace",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "workspaces": [
    "app",
    "relay"
  ],
  "scripts": {
    "dev:app": "npm run -w app dev",
    "lint": "npm run lint:app && npm run lint:relay",
    "lint:app": "npm run -w app lint",
    "lint:relay": "npm run -w relay lint",
    "build": "npm run build:app && npm run build:relay",
    "build:app": "npm run -w app build",
    "build:relay": "npm run -w relay build",
    "preview": "node scripts/preview.mjs",
    "typecheck:relay": "npm run -w relay typecheck",
    "capture:guide-media": "node app/scripts/run-capture-with-preview.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.0"
  }
}
